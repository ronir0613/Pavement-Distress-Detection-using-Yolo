# =============================================================================
# Pavement Distress Detection — .gitignore
# =============================================================================

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python

# Virtual environments
.venv/
venv/
env/
ENV/

# ── FastAPI / Backend runtime ─────────────────────────────────────────────────
backend/uploads/*
backend/predictions/*
backend/history.json
!backend/uploads/.gitkeep
!backend/predictions/.gitkeep

# Model weights (large binaries — store with Git LFS or externally)
backend/models/*.pt
backend/models/*.pth
backend/models/*.onnx
backend/models/*.torchscript

# ── Node / Frontend ───────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ── Environment files ─────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
# Keep the example so teammates know what vars are needed
!.env.example
!frontend/.env.example

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Docker ────────────────────────────────────────────────────────────────────
# (Keep Dockerfiles tracked; ignore generated artifacts)
.dockerignore

# ── Misc ─────────────────────────────────────────────────────────────────────
*.bak
*.tmp
.cache/
